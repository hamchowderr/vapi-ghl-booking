# ──────────────────────────────────────────────────────────────────────────
# Single-client VAPI × GoHighLevel booking — environment variables
# Copy to .env.local (local dev), and set the same in your host dashboard
# (Vercel → Environment Variables, or Netlify → Site config → Environment variables).
# For `netlify dev` specifically, copy to .env instead (it reads .env, not .env.local).
# ──────────────────────────────────────────────────────────────────────────

# ── GoHighLevel ────────────────────────────────────────────────────────────
GHL_PIT=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # Private Integration Token (calendars + contacts scopes)
GHL_CALENDAR_ID=                                   # the calendar to book into
GHL_LOCATION_ID=                                   # the sub-account / location id
GHL_ASSIGNED_USER_ID=                              # user the appointment is assigned to -> drives which Gmail it syncs to
GHL_TIMEZONE=America/New_York                      # IANA tz of the business calendar

# ── VAPI ───────────────────────────────────────────────────────────────────
VAPI_ASSISTANT_ID=                                 # returned by /api/assistant-request at call start

# ── Per-call cache ─────────────────────────────────────────────────────────
# On NETLIFY: leave these blank — the cache uses built-in Netlify Blobs
# automatically (zero config, no account, no env vars).
# On VERCEL / local: set these (Upstash Redis REST), or use Vercel's Upstash
# integration which injects KV_REST_API_URL / KV_REST_API_TOKEN instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── SMS provider (pick ONE) ────────────────────────────────────────────────
# "ghl"    -> sends via the location's connected LC Phone number (no extra vars)
# "twilio" -> set the TWILIO_* vars below
# "telnyx" -> set the TELNYX_* vars below
# "vapi"   -> the assistant's own sms tool sends; no server vars needed
SMS_PROVIDER=ghl

# Only if SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                                       # +1XXXXXXXXXX

# Only if SMS_PROVIDER=telnyx
TELNYX_API_KEY=
TELNYX_FROM=                                        # +1XXXXXXXXXX
TELNYX_MESSAGING_PROFILE_ID=                        # optional

# ── Closures (optional) ────────────────────────────────────────────────────
# Currently informational only — GHL free-slots already exclude closed days,
# so these aren't required for booking to work. Wire into the date-resolver later.
CLOSURE_WEEKEND_DAYS=0,6                             # 0=Sun ... 6=Sat
CLOSURE_HOLIDAYS=                                    # e.g. 2026-07-04,2026-12-25

# ── Setup only — NOT deployed ──────────────────────────────────────────────
# Used by you in the `POST /tool` cURL to register tools. The running functions
# never call VAPI, so this does not need to be a Vercel env var.
# VAPI_PRIVATE_KEY=
