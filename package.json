{
  "name": "vapi-ghl-booking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-client VAPI voice assistant that books/reschedules GoHighLevel appointments, on Vercel or Netlify Functions.",
  "scripts": {
    "deploy": "vercel --prod",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "dev:netlify": "netlify dev",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9"
  }
}
